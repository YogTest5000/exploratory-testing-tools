class FileHelper:
    """Utility helper for reading files and extracting plottable data."""

    @staticmethod
    def read_text_file(file_path):
        try:
            with open(file_path, "r", encoding="utf-8") as file:
                return file.read()
        except Exception as exc:
            raise RuntimeError(f"Failed to read file: {exc}")

    @staticmethod
    def load_tabular_data(file_path):
        """
        Supports CSV or JSON.
        Returns a DataFrame-like object if pandas is installed.
        """
        if pd is None:
            raise RuntimeError("pandas is required to load CSV/JSON data for chart plotting.")

        extension = os.path.splitext(file_path)[1].lower()

        try:
            if extension == ".csv":
                df = pd.read_csv(file_path)
            elif extension == ".json":
                with open(file_path, "r", encoding="utf-8") as f:
                    data = json.load(f)
                df = pd.json_normalize(data) if isinstance(data, (dict, list)) else pd.DataFrame(data)
            else:
                raise RuntimeError("Unsupported file format. Please select a CSV or JSON file.")
        except Exception as exc:
            raise RuntimeError(f"Failed to load data: {exc}")

        if df.empty:
            raise RuntimeError("Loaded file contains no data.")

        return df


