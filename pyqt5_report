    @staticmethod
    def save_html_report(html_content):
        default_name = f"report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.html"
        return default_name, html_content


class TabOne(QWidget):
    """Tab 1: Browse file, enter comments, generate beautiful HTML report."""

    def __init__(self):
        super().__init__()
        self.selected_file = ""
        self.init_ui()

    def init_ui(self):
        main_layout = QVBoxLayout()
        main_layout.setSpacing(15)

        title = QLabel("Tab 1 - HTML Report Generator")
        title.setFont(QFont("Arial", 14, QFont.Bold))

        self.file_label = QLabel("No file selected")
        self.file_label.setWordWrap(True)

        browse_button = QPushButton("Browse File")
        browse_button.clicked.connect(self.browse_file)

        self.comments_text = QTextEdit()
        self.comments_text.setPlaceholderText("Add comments here...")
        self.comments_text.setMinimumHeight(250)

        generate_button = QPushButton("Generate Report")
        generate_button.clicked.connect(self.generate_report)

        main_layout.addWidget(title)
        main_layout.addWidget(self.file_label)
        main_layout.addWidget(browse_button)
        main_layout.addWidget(self.comments_text)
        main_layout.addWidget(generate_button)

        self.setLayout(main_layout)

    def browse_file(self):
        file_path, _ = QFileDialog.getOpenFileName(
            self,
            "Select File",
            "",
            "All Files (*.*)"
        )
        if file_path:
            self.selected_file = file_path
            self.file_label.setText(f"Selected File: {file_path}")

    def generate_report(self):
        comments = self.comments_text.toPlainText().strip()

        if not comments:
            QMessageBox.warning(self, "Validation Error", "Please add comments before generating the report.")
            return

        try:
            html_content = HtmlReportGenerator.generate_html(self.selected_file, comments)
            default_name, html_data = HtmlReportGenerator.save_html_report(html_content)

            save_path, _ = QFileDialog.getSaveFileName(
                self,
                "Save HTML Report",
                default_name,
                "HTML Files (*.html)"
            )

            if save_path:
                with open(save_path, "w", encoding="utf-8") as file:
                    file.write(html_data)

                QMessageBox.information(self, "Success", f"HTML report generated successfully.\n\nSaved to:\n{save_path}")

        except Exception as exc:
            QMessageBox.critical(self, "Error", f"Failed to generate report.\n\n{exc}")


class TabTwo(QWidget):
    """Tab 2: Browse file and display a Bokeh chart."""

    def __init__(self):
        super().__init__()
        self.selected_file = ""
        self.init_ui()

    def init_ui(self):
        main_layout = QVBoxLayout()
        main_layout.setSpacing(15)

        title = QLabel("Tab 2 - Bokeh Chart Plotting")
        title.setFont(QFont("Arial", 14, QFont.Bold))

        self.file_label = QLabel("No file selected")
        self.file_label.setWordWrap(True)

        browse_button = QPushButton("Browse File")
        browse_button.clicked.connect(self.browse_file)

        self.status_label = QLabel("Load a CSV or JSON file to plot.")
        self.status_label.setWordWrap(True)

        if WEB_ENGINE_AVAILABLE:
            self.chart_view = QWebEngineView()
            self.chart_view.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
            main_layout.addWidget(title)
            main_layout.addWidget(self.file_label)
            main_layout.addWidget(browse_button)
            main_layout.addWidget(self.status_label)
            main_layout.addWidget(self.chart_view)
        else:
            fallback_label = QLabel(
                "PyQtWebEngine is not installed.\n"
                "Install it to display Bokeh charts inside the application:\n"
                "pip install PyQtWebEngine"
            )
            fallback_label.setWordWrap(True)

            main_layout.addWidget(title)
            main_layout.addWidget(self.file_label)
            main_layout.addWidget(browse_button)
            main_layout.addWidget(self.status_label)
            main_layout.addWidget(fallback_label)

        self.setLayout(main_layout)

    def browse_file(self):
        file_path, _ = QFileDialog.getOpenFileName(
            self,
            "Select CSV or JSON File",
            "",
            "Data Files (*.csv *.json);;All Files (*.*)"
        )
        if file_path:
            self.selected_file = file_path
            self.file_label.setText(f"Selected File: {file_path}")
            self.plot_chart()

    def plot_chart(self):
        if not WEB_ENGINE_AVAILABLE:
            return

        try:
            df = FileHelper.load_tabular_data(self.selected_file)

            numeric_columns = df.select_dtypes(include=["number"]).columns.tolist()
            if not numeric_columns:
                raise RuntimeError("No numeric columns found in the selected file.")

            y_column = numeric_columns[0]

            if len(df) > 50:
                df = df.head(50)

            x_values = list(range(1, len(df) + 1))
            y_values = df[y_column].fillna(0).tolist()

            plot = figure(
                title=f"Bokeh Plot - {y_column}",
                x_axis_label="Row Index",
                y_axis_label=y_column,
                sizing_mode="stretch_both",
                height=500,
                tools="pan,wheel_zoom,box_zoom,reset,save,hover"
            )

            plot.line(x_values, y_values, line_width=2, legend_label=y_column)
            plot.circle(x_values, y_values, size=8)
            plot.legend.location = "top_left"

            html = file_html(plot, CDN, f"Bokeh Chart - {y_column}")

            temp_html = os.path.join(tempfile.gettempdir(), "bokeh_chart_preview.html")
            with open(temp_html, "w", encoding="utf-8") as f:
                f.write(html)

            self.chart_view.loadFinished.connect(self.on_load_finished)
            self.chart_view.setUrl(Qt.QUrl.fromLocalFile(temp_html)) if hasattr(Qt, "QUrl") else self.chart_view.setHtml(html)

            # Fallback
            try:
                from PyQt5.QtCore import QUrl
                self.chart_view.setUrl(QUrl.fromLocalFile(temp_html))
            except Exception:
                self.chart_view.setHtml(html)

            self.status_label.setText(f"Plotted numeric column: {y_column}")

        except Exception as exc:
            QMessageBox.critical(self, "Plot Error", f"Failed to plot chart.\n\n{exc}")
            self.status_label.setText("Failed to plot chart.")

    def on_load_finished(self, ok):
        if not ok:
            self.status_label.setText("Chart page failed to load.")


class MainWindow(QMainWindow):
    """Main application window with tab-based scalable architecture."""

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Scalable PyQt5 Multi-Tab Desktop App")
        self.resize(1200, 800)
        self.init_ui()
        self.apply_dark_theme()

    def init_ui(self):
        central_widget = QWidget()
        main_layout = QVBoxLayout()

        header = QLabel("PyQt5 Scalable Desktop Application")
        header.setFont(QFont("Arial", 16, QFont.Bold))
        header.setAlignment(Qt.AlignCenter)

        separator = QFrame()
        separator.setFrameShape(QFrame.HLine)
        separator.setFrameShadow(QFrame.Sunken)

        self.tabs = QTabWidget()
        self.tabs.addTab(TabOne(), "Report Generator")
        self.tabs.addTab(TabTwo(), "Bokeh Chart")

        main_layout.addWidget(header)
        main_layout.addWidget(separator)
        main_layout.addWidget(self.tabs)

        central_widget.setLayout(main_layout)
        self.setCentralWidget(central_widget)

        self.statusBar().showMessage("Ready")

