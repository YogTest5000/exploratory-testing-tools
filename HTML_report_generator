    def generate_html_report(self):
        user_text = self.text_area.toPlainText().strip()

        if not user_text:
            QMessageBox.warning(
                self,
                "Input Error",
                "Please enter some text before generating the report."
            )
            return

        sections = self.extract_sections(user_text)
        dampers = self.extract_damper_positions(user_text)

        save_path, _ = QFileDialog.getSaveFileName(
            self,
            "Save HTML Report",
            "report.html",
            "HTML Files (*.html)"
        )

        if not save_path:
            return

        if not save_path.lower().endswith(".html"):
            save_path += ".html"

        html_content = self.build_html_report(sections, dampers)

        try:
            with open(save_path, "w", encoding="utf-8") as file:
                file.write(html_content)

            QMessageBox.information(
                self,
                "Success",
                f"HTML report generated successfully.\n\nSaved at:\n{os.path.abspath(save_path)}"
            )
        except Exception as e:
            QMessageBox.critical(
                self,
                "Error",
                f"Failed to save HTML report.\n\nError: {str(e)}"
            )


