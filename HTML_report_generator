    def extract_sections(self, text):
        sections = {
            "System": "",
            "LogAnalysis": "",
            "Zone1": "",
            "Zone2": "",
            "Zone3": ""
        }

        pattern = (
            r"\[(System|LogAnalysis|Zone1|Zone2|Zone3)\]"
            r"(.*?)(?=\[(?:System|LogAnalysis|Zone1|Zone2|Zone3)\]|\[Damper\s+Position\s+\d{1,3}%\]|$)"
        )

        matches = re.findall(pattern, text, re.DOTALL | re.IGNORECASE)

        for section_name, content in matches:
            normalized_name = self.normalize_section_name(section_name)
            cleaned_content = content.strip()

            if sections[normalized_name]:
                sections[normalized_name] += "\n\n" + cleaned_content
            else:
                sections[normalized_name] = cleaned_content

        return sections

    def normalize_section_name(self, name):
        name_lower = name.strip().lower()
        mapping = {
            "system": "System",
            "loganalysis": "LogAnalysis",
            "zone1": "Zone1",
            "zone2": "Zone2",
            "zone3": "Zone3"
        }
        return mapping.get(name_lower, name)

    def extract_damper_positions(self, text):
        """
        Finds tags like:
        [Damper Position 30%]
        [Damper Position 75%]
        [Damper Position 100%]

        Returns exactly 3 damper items.
        Missing entries are filled with 0%.
        """
        pattern = r"\[Damper\s+Position\s+(\d{1,3})%\]"
        matches = re.findall(pattern, text, re.IGNORECASE)

        dampers = []
        for index, value in enumerate(matches[:3], start=1):
            percent = max(0, min(100, int(value)))
            dampers.append({
                "label": f"Damper {index}",
                "value": percent,
                "highlight": True
            })

        while len(dampers) < 3:
            dampers.append({
                "label": f"Damper {len(dampers) + 1}",
                "value": 0,
                "highlight": False
            })

        return dampers

    def format_text(self, text):
        if not text.strip():
            return "<em>No Data</em>"
        return html.escape(text).replace("\n", "<br>")

    def build_damper_chart_html(self, damper):
        percent = damper["value"]
        degrees = int((percent / 100) * 360)
        highlight_class = "damper-card highlight" if damper["highlight"] else "damper-card"

        return f"""
        <div class="{highlight_class}">
            <div class="damper-title">{html.escape(damper["label"])}</div>
            <div class="pie-wrapper">
                <div class="pie-chart" style="background: conic-gradient(#4a90e2 0deg {degrees}deg, #e6edf5 {degrees}deg 360deg);">
                    <div class="pie-center">{percent}%</div>
                </div>
            </div>
            <div class="damper-status">Position: {percent}%</div>
        </div>
        """

    def build_html_report(self, sections, dampers):
