        zone1_text = self.format_text(sections["Zone1"])
        zone2_text = self.format_text(sections["Zone2"])
        zone3_text = self.format_text(sections["Zone3"])

        damper_charts_html = "\n".join(
            self.build_damper_chart_html(damper) for damper in dampers
